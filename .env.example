# Umami API URL for server-side polling (e.g., https://analytics.example.com or internal network URL)
UMAMI_API_ENDPOINT=

# Public-facing Umami URL for browser links (defaults to UMAMI_API_ENDPOINT if not set)
UMAMI_PUBLIC_URL=

# Umami login credentials (use a dedicated read-only account)
UMAMI_USERNAME=
UMAMI_PASSWORD=

# JSON array of websites to monitor
# Get website IDs from Umami dashboard: Settings → Websites
# Format: [{"id":"website-uuid","name":"Display Name"}]
UMAMI_WEBSITES=

# Dashboard grid layout
GRID_COLUMNS=3
GRID_ROWS=2

# Poll interval in milliseconds
POLL_INTERVAL_MS=5000

# Server port
PORT=3000
