{
  "name": "umamidash-vue",
  "version": "0.1.0",
  "description": "Realtime analytics dashboard for self-hosted Umami instances",
  "author": "Charles Jones",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/charlesjones-dev/umamidash-vue.git"
  },
  "keywords": [
    "umami",
    "analytics",
    "dashboard",
    "realtime",
    "vue",
    "sse"
  ],
  "type": "module",
  "scripts": {
    "setup:doppler": "node scripts/setup-doppler.js",
    "dev": "doppler run -- concurrently \"node server.js\" \"vite\"",
    "dev:client": "doppler run -- vite",
    "dev:server": "doppler run -- node server.js",
    "build": "vite build",
    "start": "node server.js"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^4.21.2",
    "leaflet": "^1.9.4",
    "lucide-vue-next": "^0.474.0",
    "reka-ui": "^2.8.0",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.7",
    "@types/express": "^5.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.13.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
